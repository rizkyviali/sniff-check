{
  "name": "sniff-check",
  "version": "0.2.5",
  "description": "🎯 Opinionated TypeScript/Next.js Development Toolkit - Find large files, unused imports, broken imports, and enforce code quality standards with lightning speed",
  "bin": {
    "sniff": "./bin/sniff"
  },
  "scripts": {
    "preinstall": "node preinstall.js",
    "postinstall": "node install.js",
    "test": "cargo test"
  },
  "keywords": [
    "typescript",
    "nextjs",
    "next.js",
    "code-quality",
    "cli",
    "development",
    "linting",
    "performance",
    "memory-leak",
    "bundle-analysis",
    "imports",
    "unused-imports",
    "broken-imports",
    "refactoring",
    "type-checking",
    "static-analysis",
    "developer-tools",
    "code-analysis",
    "rust-cli"
  ],
  "author": "Rizky Viali",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rizkyviali/sniff-check"
  },
  "bugs": {
    "url": "https://github.com/rizkyviali/sniff-check/issues"
  },
  "homepage": "https://github.com/rizkyviali/sniff-check#readme",
  "funding": {
    "type": "ko-fi",
    "url": "https://ko-fi.com/rizkyviali"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true,
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "bin/",
    "install.js",
    "preinstall.js",
    "README.md",
    "src/",
    "Cargo.toml",
    "Cargo.lock"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.11"
  }
}
