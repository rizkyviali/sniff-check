{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": [
      "*.js",
      "*.json",
      "!!target/",
      "!!.claude/",
      "!!node_modules/",
      "!!bin/"
    ]
  }
}
